# Beautiful Women - Variables d'environnement
# ============================================================
# COPIER CE FICHIER EN .env et remplir les valeurs
# NE JAMAIS COMMITER LE FICHIER .env SUR GITHUB !
# ============================================================

# ===== SERVEUR =====
PORT=3000
NODE_ENV=production

# ===== BASE DE DONNÉES MySQL (Railway fournit ces valeurs automatiquement) =====
# Sur Railway : copiez depuis Variables > MySQL service
DB_HOST=your-mysql-host.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_railway_mysql_password
DB_NAME=beautiful_women

# ===== JWT (clé secrète de sécurité - choisissez une longue chaîne aléatoire) =====
JWT_SECRET=changez_moi_avec_une_cle_tres_longue_et_aleatoire_abc123xyz
JWT_EXPIRES_IN=7d

# ===== URL DE BASE (URL de votre backend Railway) =====
BASE_URL=https://votre-backend.railway.app

# ===== URL DU FRONTEND (pour CORS en production) =====
# Si Railway sert tout : même valeur que BASE_URL
# Si Netlify séparé : mettre l'URL Netlify
FRONTEND_URL=https://votre-backend.railway.app

# ===== CLOUDINARY (optionnel - pour stocker les images en cloud) =====
# Gratuit sur cloudinary.com → 25 Go de stockage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== CINETPAY (paiement réel Côte d'Ivoire - optionnel) =====
# Sans ces clés : le paiement reste en mode simulation (parfait pour soutenance)
# CINETPAY_API_KEY=your_cinetpay_api_key
# CINETPAY_SITE_ID=your_site_id
# CINETPAY_NOTIFY_URL=https://votre-backend.railway.app/api/commandes/notification
# CINETPAY_RETURN_URL=https://votre-backend.railway.app/profil.html
