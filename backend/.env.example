# Beautiful Women - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# ===== SERVEUR =====
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ===== BASE DE DONNÉES MySQL =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=beautiful_women

# ===== JWT =====
JWT_SECRET=beautiful_women_secret_key_2025_abidjan
JWT_EXPIRES_IN=7d

# ===== CLOUDINARY (stockage images) =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== CINETPAY (paiement Côte d'Ivoire) =====
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_site_id
CINETPAY_NOTIFY_URL=https://votre-domaine.com/api/paiement/notify
CINETPAY_RETURN_URL=https://votre-domaine.com/panier.html
