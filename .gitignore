# ============================================================
# .gitignore - Beautiful Women
# ============================================================

# ── Dépendances Node ────────────────────────────────────────
node_modules/
backend/node_modules/

# ── Variables d'environnement (NE JAMAIS COMMITER) ──────────
.env
backend/.env

backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/wax_hollandais_1.jpg
!backend/uploads/bazin_1.jpg
!backend/uploads/kente_1.jpg
!backend/uploads/bogolan_1.jpg
!backend/uploads/robe_wax_1.jpg
!backend/uploads/ensemble_bazin_1.jpg
!backend/uploads/produit_15_0.jpg
!backend/uploads/pagne_kita.jpg
!backend/uploads/modele_ankara.jpg
!backend/uploads/modele_kente.jpg
!backend/uploads/modele_bogolan.jpg
!backend/uploads/modele_kita.jpg
!backend/uploads/tissu_ankara.jpg

# ── Fichiers de log ─────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Fichiers système ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Documents Word (trop lourds pour Git) ───────────────────
*.docx
*.doc
~$*.docx

# ── Fichiers de test/debug locaux ───────────────────────────
backend/test.jpg
backend/reproduce-issue.js
backend/debug-db.js
backend/scratch_db_diag.js
debug-images.html
dependencies.csv

# ── Fichiers de génération de mémoire (scripts locaux) ──────
backend/generate-memoire.js
backend/generate-merise-doc.js
backend/generate-intro.js
backend/compress-static-images.js
backend/optimize-all-images.js

# ── Tunnels (locaux uniquement) ─────────────────────────────
lancer-tunnel.bat
lancer-tunnel-ngrok.bat
LANCER_SERVEUR.bat
DEMARRER.bat
demarrer-serveur.bat

# ── Build (si ajouté plus tard) ─────────────────────────────
dist/
build/
